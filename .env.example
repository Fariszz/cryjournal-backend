# App
NODE_ENV=development
PORT=3000

# Database
DB_URL=postgresql://postgres:postgres@localhost:5432/postgres

# JWT
JWT_SECRET=local-jwt-secret-change-me
JWT_EXPIRES_IN=3600

# Google OAuth
GOOGLE_CLIENT_ID=replace-google-client-id
GOOGLE_CLIENT_SECRET=replace-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880

# Login Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Admin Seeder (used by drizzle/seed/index.ts)
ADMIN_EMAIL=admin@cryjournal.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
